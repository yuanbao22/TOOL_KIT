<Window x:Class="AbaqusToolkit.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:hc="https://handyorg.github.io/handycontrol"
        Title="Abaqus 工具包"
        Width="1200"
        Height="800"
        WindowStartupLocation="CenterScreen">

    <Grid>
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="Auto" />
            <ColumnDefinition Width="*" />
        </Grid.ColumnDefinitions>

        <!-- Left Navigation Sidebar -->
        <Border Grid.Column="0"
                Width="220"
                Background="{DynamicResource RegionBrush}">
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="*" />
                    <RowDefinition Height="Auto" />
                </Grid.RowDefinitions>

                <!-- App Title -->
                <TextBlock Text="Abaqus 工具包"
                           FontSize="16"
                           FontWeight="Bold"
                           Foreground="{DynamicResource PrimaryBrush}"
                           Margin="16,20,16,12" />

                <!-- Navigation Menu -->
                <hc:SideMenu x:Name="NavSideMenu"
                             Grid.Row="1"
                             AutoSelect="True"
                             SelectionChanged="OnNavChanged"
                             Background="Transparent"
                             BorderThickness="0">

                    <hc:SideMenuItem Header="首页"
                                      Tag="Dashboard">
                        <hc:SideMenuItem.Icon>
                            <Path Data="M10,20V14H14V20H19V12H22L12,3L2,12H5V20H10Z"
                                  Width="20"
                                  Height="20"
                                  Fill="{DynamicResource PrimaryBrush}"
                                  Stretch="Uniform" />
                        </hc:SideMenuItem.Icon>
                    </hc:SideMenuItem>

                    <hc:SideMenuItem Header="INP 合并"
                                     Tag="Merge">
                        <hc:SideMenuItem.Icon>
                            <Path Data="M3.9,12C3.9,10.29 5.29,8.9 7,8.9H11V7H7A5,5 0 0,0 2,12A5,5 0 0,0 7,17H11V15.1H7C5.29,15.1 3.9,13.71 3.9,12M8,13H16V11H8V13M17,7H13V8.9H17C18.71,8.9 20.1,10.29 20.1,12C20.1,13.71 18.71,15.1 17,15.1H13V17H17A5,5 0 0,0 22,12A5,5 0 0,0 17,7Z"
                                  Width="20"
                                  Height="20"
                                  Fill="{DynamicResource PrimaryBrush}"
                                  Stretch="Uniform" />
                        </hc:SideMenuItem.Icon>
                    </hc:SideMenuItem>

                </hc:SideMenu>

                <!-- Footer -->
                <TextBlock Grid.Row="2"
                           Text="v1.0"
                           FontSize="11"
                           Foreground="Gray"
                           Margin="16,8,16,16" />
            </Grid>
        </Border>

        <!-- Content Area -->
        <Frame x:Name="RootFrame"
               Grid.Column="1"
               NavigationUIVisibility="Hidden" />
    </Grid>
</Window>
