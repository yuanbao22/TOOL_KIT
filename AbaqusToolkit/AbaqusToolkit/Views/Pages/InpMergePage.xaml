<Page x:Class="AbaqusToolkit.Views.Pages.InpMergePage"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      xmlns:hc="https://handyorg.github.io/handycontrol"
      Title="INP 合并"
      Background="{DynamicResource RegionBrush}">

    <ScrollViewer VerticalScrollBarVisibility="Auto">
        <StackPanel Margin="32,24">

            <TextBlock Text="INP 文件合并" FontSize="28" FontWeight="Bold"
                       Foreground="{DynamicResource PrimaryBrush}" />
            <TextBlock Text="将两个 INP 文件合并为一个，自动处理节点和单元编号冲突。"
                       FontSize="14" Foreground="Gray" Margin="0,6,0,28" TextWrapping="Wrap" />

            <hc:Card Margin="0,0,0,16" Padding="0">
                <hc:Card.Header>
                    <Border Padding="20,14">
                        <TextBlock Text="文件选择" FontSize="13" FontWeight="SemiBold" />
                    </Border>
                </hc:Card.Header>
                <StackPanel Margin="20,0,20,20">

                    <Grid Margin="0,6">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="140"/>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="Auto"/>
                        </Grid.ColumnDefinitions>
                        <TextBlock Grid.Column="0" Text="Job-1（主文件）：" VerticalAlignment="Center" FontSize="14"/>
                        <TextBox Grid.Column="1" Text="{Binding File1Path, Mode=TwoWay}"
                                 Margin="12,0" VerticalAlignment="Center" MinHeight="32"
                                 Style="{StaticResource TextBoxExtend}"/>
                        <Button Grid.Column="2" Command="{Binding BrowseFile1Command}"
                                Content="浏览" Padding="16,6" VerticalAlignment="Center"/>
                    </Grid>

                    <Grid Margin="0,10">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="140"/>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="Auto"/>
                        </Grid.ColumnDefinitions>
                        <TextBlock Grid.Column="0" Text="Job-2（次文件）：" VerticalAlignment="Center" FontSize="14"/>
                        <TextBox Grid.Column="1" Text="{Binding File2Path, Mode=TwoWay}"
                                 Margin="12,0" VerticalAlignment="Center" MinHeight="32"
                                 Style="{StaticResource TextBoxExtend}"/>
                        <Button Grid.Column="2" Command="{Binding BrowseFile2Command}"
                                Content="浏览" Padding="16,6" VerticalAlignment="Center"/>
                    </Grid>

                    <Grid Margin="0,10">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="140"/>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="Auto"/>
                        </Grid.ColumnDefinitions>
                        <TextBlock Grid.Column="0" Text="输出路径：" VerticalAlignment="Center" FontSize="14"/>
                        <TextBox Grid.Column="1" Text="{Binding OutputPath, Mode=TwoWay}"
                                 Margin="12,0" VerticalAlignment="Center" MinHeight="32"
                                 Style="{StaticResource TextBoxExtend}"/>
                        <Button Grid.Column="2" Command="{Binding BrowseOutputCommand}"
                                Content="浏览" Padding="16,6" VerticalAlignment="Center"/>
                    </Grid>
                </StackPanel>
            </hc:Card>

            <Button Command="{Binding MergeCommand}" IsEnabled="{Binding CanMerge}"
                    Style="{StaticResource ButtonPrimary}" Height="42" FontSize="14"
                    FontWeight="SemiBold" HorizontalAlignment="Stretch" Margin="0,0,0,16">
                执行合并
            </Button>

            <hc:Card Margin="0,0,0,12" Padding="0">
                <hc:Card.Header>
                    <Border Padding="20,14">
                        <TextBlock Text="输出日志" FontSize="13" FontWeight="SemiBold"/>
                    </Border>
                </hc:Card.Header>
                <ScrollViewer VerticalScrollBarVisibility="Auto" MaxHeight="300" Margin="20,0,20,20">
                    <TextBox Text="{Binding MergeLog, Mode=OneWay}" IsReadOnly="True"
                             FontFamily="Consolas" FontSize="12" TextWrapping="Wrap"
                             Background="Transparent" BorderThickness="0" MinHeight="120"
                             Style="{StaticResource TextBoxExtend}"/>
                </ScrollViewer>
            </hc:Card>

            <Border Padding="12,8" CornerRadius="4" Background="{DynamicResource InfoBrush}">
                <TextBlock Text="{Binding StatusMessage, Mode=OneWay}" FontSize="13"
                           Foreground="White" TextWrapping="Wrap"/>
            </Border>

        </StackPanel>
    </ScrollViewer>
</Page>
