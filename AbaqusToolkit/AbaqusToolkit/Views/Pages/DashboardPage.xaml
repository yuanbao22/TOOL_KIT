<Page x:Class="AbaqusToolkit.Views.Pages.DashboardPage"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      xmlns:hc="https://handyorg.github.io/handycontrol"
      Title="首页"
      Background="{DynamicResource RegionBrush}">

    <Grid>
        <StackPanel VerticalAlignment="Center"
                    HorizontalAlignment="Center"
                    MaxWidth="500">

            <!-- Icon -->
            <Border Width="80"
                    Height="80"
                    CornerRadius="40"
                    Background="{DynamicResource PrimaryBrush}"
                    HorizontalAlignment="Center"
                    Margin="0,0,0,24">
                <Path Data="M12,3L2,12H5V20H19V12H22L12,3M9,18H7V12H9V18M13,18H11V10H13V18M17,18H15V14H17V18"
                      Width="40"
                      Height="40"
                      Fill="White"
                      Stretch="Uniform" />
            </Border>

            <!-- Welcome Text -->
            <TextBlock Text="欢迎使用 Abaqus 工具包"
                       FontSize="28"
                       FontWeight="Bold"
                       HorizontalAlignment="Center"
                       TextAlignment="Center" />

            <TextBlock Text="Abaqus INP 文件管理专业工具集"
                       FontSize="15"
                       Foreground="Gray"
                       HorizontalAlignment="Center"
                       TextAlignment="Center"
                       Margin="0,10,0,0"
                       TextWrapping="Wrap" />

            <!-- Quick Actions Card -->
            <hc:Card Margin="0,32,0,0"
                     Padding="0">
                <hc:Card.Header>
                    <Border Padding="20,14">
                        <TextBlock Text="快捷操作"
                                   FontSize="13"
                                   FontWeight="SemiBold" />
                    </Border>
                </hc:Card.Header>

                <StackPanel Margin="20,12,20,20">
                    <hc:Card Margin="0,4"
                             Padding="16">
                        <StackPanel Orientation="Horizontal">
                            <Path Data="M3.9,12C3.9,10.29 5.29,8.9 7,8.9H11V7H7A5,5 0 0,0 2,12A5,5 0 0,0 7,17H11V15.1H7C5.29,15.1 3.9,13.71 3.9,12M8,13H16V11H8V13M17,7H13V8.9H17C18.71,8.9 20.1,10.29 20.1,12C20.1,13.71 18.71,15.1 17,15.1H13V17H17A5,5 0 0,0 22,12A5,5 0 0,0 17,7Z"
                                  Width="24"
                                  Height="24"
                                  Fill="{DynamicResource PrimaryBrush}"
                                  Stretch="Uniform"
                                  Margin="0,0,12,0" />
                            <StackPanel>
                                <TextBlock Text="INP 文件合并"
                                           FontSize="15"
                                           FontWeight="SemiBold" />
                                <TextBlock Text="将两个 INP 文件合并为一个，自动处理编号冲突"
                                           FontSize="12"
                                           Foreground="Gray"
                                           Margin="0,2,0,0" />
                            </StackPanel>
                        </StackPanel>
                    </hc:Card>
                </StackPanel>
            </hc:Card>

        </StackPanel>
    </Grid>
</Page>
